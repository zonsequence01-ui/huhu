# API
PORT=3000
HOST=0.0.0.0
DATABASE_URL=file:./data/huhu.db
# Optional: postgres://huhu:huhu@localhost:5432/huhu (app data migration TBD)
# PGVECTOR_URL=postgresql://huhu:huhu@localhost:5432/huhu
# VECTOR_STORE=sqlite
JWT_SECRET=change-me-in-production
# Public web origin for invite links on GET /v1/users/me (e.g. https://app.example.com)
PUBLIC_WEB_URL=
# Store Support/Privacy URLs base (no trailing slash); client-config storeUrls + static /support.html
STORE_PUBLIC_SITE_URL=https://huhu-app.pages.dev
# Max friend requests per user per hour (default 30)
FRIEND_REQUEST_RATE_LIMIT=30
USER_SEARCH_RATE_LIMIT=60
# db | postgres = 多實例共用 rate_limit_buckets；預設 in-memory
# RATE_LIMIT_BACKEND=db

# RAG: mock | openai (uses OPENAI_API_KEY)
EMBEDDING_PROVIDER=mock
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSION=384

# TTS: mock | openai (voice messages, Basic+ tier)
TTS_PROVIDER=mock
OPENAI_TTS_MODEL=tts-1
OPENAI_VISION_MODEL=gpt-4o-mini

# LLM: mock | openai | anthropic | hybrid | llama
# hybrid = Llama (light) + cloud API (premium) when LLAMA_BASE_URL is set
LLAMA_BASE_URL=
LLAMA_MODEL=llama3
HYBRID_COMMERCIAL_PROVIDER=openai

# IAP (optional; dev uses valid_<productId> without these)
# IAP_STRICT=true rejects dev stubs when store credentials are missing
# IAP_STRICT=
APPLE_IAP_SHARED_SECRET=
APPLE_IAP_SANDBOX=1
# App Store Server API v2 (signedTransaction JWS)
# APPLE_APP_STORE_KEY_ID=
# APPLE_APP_STORE_ISSUER_ID=
# APPLE_APP_STORE_PRIVATE_KEY=   # PEM, \n escaped
# APPLE_APP_STORE_BUNDLE_ID=com.ctrlz.huhu
# APPLE_APP_STORE_JWS_DECODE_ONLY=1   # staging only — no signature verify
# APPLE_APP_STORE_ROOT_PIN=0          # disable bundled Apple Root CA G3 pinning
# APPLE_APP_STORE_TRUSTED_ROOTS_PEM=  # extra root PEM blocks (optional)
GOOGLE_PLAY_PACKAGE_NAME=com.ctrlz.huhu
# GOOGLE_PLAY_STUB=1 enables gp: token stub without service account
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"..."}
# Render Secret File (recommended): upload google-play-sa.json → auto-read at:
# GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=/etc/secrets/google-play-sa.json

# Public moment moderation (unique reports before auto-hide from community feed)
MOMENT_REPORT_HIDE_THRESHOLD=3
# Optional: x-admin-key header for GET /v1/admin/moments/hidden and POST .../restore
ADMIN_API_KEY=

# Offerwall HMAC (optional; clients call POST /v1/rewards/offerwall/prepare then /offerwall)
OFFERWALL_SECRET=
# OFFERWALL_ALLOWED_IPS=203.0.113.10,203.0.113.11

# Age gate (set AGE_GATE=0 to disable in dev)
AGE_GATE=1

# Smoke / launch (local scripts only)
# SMOKE_PORT=31998
# SKIP_SMOKE=1
