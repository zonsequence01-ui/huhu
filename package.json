{
  "name": "huhu",
  "version": "0.1.0",
  "private": true,
  "description": "呼呼 Huhu AI companion platform (com.ctrlz.huhu)",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:integration": "pnpm --filter @huhu/api run test:integration",
    "db:migrate-to-postgres": "node scripts/migrate-sqlite-to-postgres.mjs",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "export:store-catalog": "node scripts/export-store-catalog.mjs",
    "export:store-catalog:files": "node scripts/export-store-catalog.mjs --out dist/store-catalog",
    "validate:store-listings": "node scripts/validate-store-listings.mjs",
    "validate:public-pages": "node scripts/validate-public-pages.mjs",
    "validate:store-catalog": "node scripts/validate-store-catalog.mjs",
    "validate:dist-store-catalog": "node scripts/validate-dist-store-catalog.mjs",
    "check:iap": "node scripts/check-iap-readiness.mjs",
    "check:launch": "node scripts/check-launch-readiness.mjs",
    "rebuild:native": "pnpm rebuild better-sqlite3",
    "export:aso-brief": "node scripts/export-aso-brief.mjs",
    "capture:aso-screenshots": "node scripts/capture-aso-screenshots.mjs",
    "validate:aso-screenshots": "node scripts/validate-aso-screenshots.mjs",
    "validate:aso-screenshots:all": "node scripts/validate-aso-screenshots.mjs --all",
    "resize:aso-play-screenshots": "node scripts/resize-aso-play-screenshots.mjs",
    "resize:aso-app-store-screenshots": "node scripts/resize-aso-app-store-screenshots.mjs",
    "validate:aso-play-screenshots": "node scripts/validate-aso-play-screenshots.mjs",
    "validate:aso-play-screenshots:all": "node scripts/validate-aso-play-screenshots.mjs --all",
    "compose:aso-screenshots": "node scripts/compose-aso-screenshots.mjs",
    "validate:aso-captioned": "node scripts/validate-aso-captioned.mjs",
    "validate:aso-captioned:all": "node scripts/validate-aso-captioned.mjs --all",
    "export:iap-store-checklist": "node scripts/export-iap-store-checklist.mjs",
    "validate:iap-store-checklist": "node scripts/validate-iap-store-checklist.mjs",
    "package:store-upload": "node scripts/package-store-upload.mjs",
    "generate:store-graphics": "node scripts/generate-store-graphics.mjs",
    "validate:store-upload": "node scripts/validate-store-upload.mjs",
    "package:launch-bundle": "node scripts/package-launch-bundle.mjs",
    "validate:launch-bundle": "node scripts/validate-launch-bundle.mjs",
    "export:operations-status": "node scripts/export-operations-status.mjs",
    "validate:operations-status": "node scripts/validate-operations-status.mjs",
    "setup:android-signing": "node scripts/setup-android-signing.mjs",
    "build:android": "node scripts/setup-android-signing.mjs && cd apps/mobile && flutter build appbundle --release --dart-define=API_BASE=https://huhu-app.pages.dev",
    "build:android:apk": "node scripts/setup-android-signing.mjs && cd apps/mobile && flutter build apk --release",
    "package:android-release": "node scripts/package-android-release.mjs",
    "validate:android-release": "node scripts/validate-android-release.mjs",
    "export:play-iap-products": "node scripts/export-play-iap-products.mjs",
    "export:app-store-connect": "node scripts/export-app-store-connect.mjs",
    "export:iap-review-screenshots": "node scripts/export-iap-review-screenshots.mjs",
    "serve:iap-review-png": "node scripts/serve-iap-review-png.mjs",
    "serve:store-upload-png": "node scripts/serve-store-upload-png.mjs",
    "serve:android-aab": "node scripts/serve-android-aab.mjs",
    "set:pages-api-origin": "node scripts/set-pages-api-origin.mjs",
    "validate:ios-config": "node scripts/validate-ios-config.mjs",
    "package:ios-release": "node scripts/package-ios-release.mjs",
    "build:ios": "cd apps/mobile && flutter build ipa --release --dart-define=API_BASE=https://huhu-app.pages.dev",
    "deploy:pages": "node scripts/deploy-cloudflare-pages.mjs",
    "verify": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm smoke:api:local && pnpm check:launch",
    "prelaunch": "pnpm verify && pnpm test:e2e",
    "smoke:api": "node scripts/smoke-public-api.mjs",
    "smoke:api:local": "node scripts/run-smoke-with-api.mjs",
    "smoke:api:prod": "node scripts/smoke-production-site.mjs",
    "check:site": "node scripts/check-production-site.mjs",
    "wait:site": "node scripts/wait-for-production-site.mjs",
    "verify:docker": "node scripts/verify-docker-image.mjs",
    "export:deploy-bundle": "node scripts/export-deploy-bundle.mjs",
    "validate:deploy-bundle": "node scripts/validate-deploy-bundle.mjs",
    "generate:jwt-secret": "node scripts/generate-jwt-secret.mjs",
    "start:prod-stack": "node scripts/start-local-prod-stack.mjs",
    "health:prod-stack": "node scripts/health-prod-stack.mjs",
    "check:render": "node scripts/check-render-api.mjs",
    "push:github": "node scripts/push-github.mjs",
    "ship:android": "pnpm build:android && pnpm package:android-release && pnpm validate:android-release",
    "dev": "pnpm --filter @huhu/api run dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huhu/shared": "workspace:*"
  },
  "packageManager": "pnpm@9.15.0"
}
